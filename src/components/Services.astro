            <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
              <path
                fill-rule="evenodd"
                d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8"
              />
            </svg>
          </button>
        </div>
      </div>

      <div class="service-carousel__track service-carousel__track--objective" data-carousel-track>
        {services.map((service, index) => (
          <article
            class={`service-card${service.href.includes("/diseno-de-pagina-web/") ? " service-card--web" : ""}`}
            style={`--accent:${service.accent}; --bg:url(${service.image})`}
            data-delay={index * 50}
          >
            <a class="service-card__overlay" href={service.href} aria-label={`Ver ${service.title}`}></a>
            <div class="service-card__content">
              <p class="service-card__label">Servicio recomendado</p>
              <h3>{service.title}</h3>
              <ul>
                {service.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <span class="service-card__action">Empezar ahora</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

