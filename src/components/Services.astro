<section class="objectives" id="servicios" aria-labelledby="servicios-title">
  <div class="container">
    <Reveal class="objective-copy objective-copy--center" delay={0}>
      <h2 id="servicios-title">¿Cuál es tu próximo objetivo?</h2>
      <p class="objective-copy__text">
        En Kitstation combinamos pÃƒÂ¡ginas web profesionales, Google Ads, Meta Ads, automatizaciÃƒÂ³n de WhatsApp, CRM personalizado y desarrollo web para negocios que quieren crecer con una estrategia clara.
      </p>
    </Reveal>

    <div
      class="service-carousel service-carousel--objective reveal reveal-up"
      data-reveal="up"
      data-carousel
      data-carousel-loop="5"
    >
      <div class="service-carousel__head">
        <div class="service-carousel__controls">
          <button type="button" aria-label="Objetivo anterior" data-carousel-prev>
            <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
              <path
                fill-rule="evenodd"
                d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5"
