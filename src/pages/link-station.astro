---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import "../styles/global.css";

const metrics = [
  { value: "1 panel", label: "Todos tus canales en un solo lugar" },
  { value: "75%", label: "WhatsApp liderando las conversaciones" },
  { value: "25%", label: "Tasa de conversion visible para el equipo" }
];

const features = [
  {
    title: "Bandeja unificada",
    text: "Centraliza WhatsApp, Instagram y otros puntos de contacto sin perder contexto."
  },
  {
    title: "Visibilidad del equipo",
    text: "Supervisa agentes, conversaciones activas y ventas cerradas desde el tablero."
  },
  {
    title: "Analitica clara",
    text: "Mide conversion, volumen por canal e insights del periodo en segundos."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "LinkStation",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  description:
    "LinkStation centraliza conversaciones, agentes y ventas en un CRM visual para equipos comerciales."
};
---

<BaseLayout
  title="LinkStation | CRM para centralizar conversaciones y ventas"
  description="LinkStation es una landing para presentar un CRM visual que organiza conversaciones, equipo y conversiones desde un solo tablero."
  image="/images/linkstation-crm.png"
  imageAlt="Vista del dashboard de LinkStation CRM"
  structuredData={structuredData}
>
  <Header />

  <main class="linkstation-page">
    <section class="linkstation-hero">
      <div class="container linkstation-hero__inner">
        <div class="linkstation-copy reveal reveal-up">
          <span class="linkstation-badge">LINKSTATION CRM</span>
          <h1>El CRM visual para equipos que venden y responden mas rapido.</h1>
          <p>
            Centraliza conversaciones, monitorea agentes y revisa resultados en un
            solo tablero pensado para equipos comerciales y de atencion al cliente.
          </p>

          <div class="linkstation-actions">
            <a class="linkstation-button linkstation-button--primary" href="/contactanos/">
              Solicitar demo
            </a>
            <a class="linkstation-button linkstation-button--ghost" href="#overview">
              Ver tablero
            </a>
          </div>
        </div>

        <div class="linkstation-stage reveal reveal-up" id="overview">
          <div class="linkstation-glow linkstation-glow--left"></div>
          <div class="linkstation-glow linkstation-glow--right"></div>
          <div class="linkstation-stars" aria-hidden="true"></div>

          <figure class="linkstation-shot">
            <img
              src="/images/linkstation-crm.png"
              alt="Dashboard principal de LinkStation CRM"
              width="1912"
              height="913"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="linkstation-metrics">
      <div class="container linkstation-metrics__grid">
        {metrics.map((item) => (
          <article class="linkstation-metric reveal reveal-up">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="linkstation-overview">
      <div class="container linkstation-overview__grid">
        <div class="linkstation-sectionhead reveal reveal-left">
          <span>VISION GENERAL</span>
          <h2>Una interfaz limpia para entender el estado comercial sin esfuerzo.</h2>
          <p>
            LinkStation ordena el trabajo diario con tarjetas de rendimiento,
            lectura por canal e insights accionables para tomar decisiones mas
            rapidas.
          </p>
        </div>

        <div class="linkstation-featurelist">
          {features.map((item) => (
            <article class="linkstation-feature reveal reveal-right">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="linkstation-cta">
      <div class="container">
        <div class="linkstation-cta__panel reveal reveal-up">
          <span>LINKSTATION</span>
          <h2>Convierte conversaciones en seguimiento, equipo y ventas visibles.</h2>
          <a class="linkstation-button linkstation-button--light" href="/contactanos/">
            Quiero una demo
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</BaseLayout>

<style>
  :root {
    --ls-bg-top: #041626;
    --ls-bg-bottom: #0a2130;
    --ls-surface: rgba(255, 255, 255, 0.08);
    --ls-surface-strong: rgba(255, 255, 255, 0.12);
    --ls-line: rgba(255, 255, 255, 0.14);
    --ls-text: #f4f8fb;
    --ls-soft: rgba(244, 248, 251, 0.72);
    --ls-accent: #59d46f;
    --ls-accent-dark: #39b452;
    --ls-shadow: 0 30px 90px rgba(2, 10, 18, 0.46);
  }

  .linkstation-page {
    background:
      radial-gradient(circle at 18% 18%, rgba(49, 184, 108, 0.14), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(77, 226, 130, 0.3), transparent 30%),
      linear-gradient(180deg, var(--ls-bg-top) 0%, var(--ls-bg-bottom) 70%, #f5f8f7 100%);
    color: var(--ls-text);
  }

  .linkstation-hero {
    position: relative;
    overflow: hidden;
    padding: 84px 0 48px;
  }

  .linkstation-hero::after {
    content: "";
    position: absolute;
    right: -12%;
    bottom: 10%;
    width: 540px;
    height: 540px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(77, 226, 130, 0.18), transparent 68%);
    filter: blur(24px);
    pointer-events: none;
  }

  .linkstation-hero__inner {
    position: relative;
    z-index: 1;
  }

  .linkstation-copy {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .linkstation-badge,
  .linkstation-sectionhead span,
  .linkstation-cta__panel span {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .linkstation-copy h1,
  .linkstation-sectionhead h2,
  .linkstation-cta__panel h2 {
    margin: 20px 0 0;
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.07em;
  }

  .linkstation-copy p,
  .linkstation-sectionhead p {
    max-width: 760px;
    margin: 22px auto 0;
    color: var(--ls-soft);
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    line-height: 1.55;
  }

  .linkstation-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .linkstation-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 0 26px;
    border: 1px solid transparent;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 600;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .linkstation-button:hover {
    transform: translateY(-2px);
  }

  .linkstation-button--primary {
    background: linear-gradient(135deg, var(--ls-accent) 0%, #67dd7d 100%);
    color: #062212;
    box-shadow: 0 18px 42px rgba(79, 212, 111, 0.28);
  }

  .linkstation-button--ghost {
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .linkstation-button--light {
    background: #fff;
    color: #0b2b1a;
  }

  .linkstation-stage {
    position: relative;
    margin-top: 56px;
    padding: 48px 0 24px;
  }

  .linkstation-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 10% 12%, rgba(255, 255, 255, 0.9) 0 1.2px, transparent 1.3px),
      radial-gradient(circle at 18% 72%, rgba(255, 255, 255, 0.55) 0 1px, transparent 1.2px),
      radial-gradient(circle at 28% 34%, rgba(255, 255, 255, 0.75) 0 1.1px, transparent 1.3px),
      radial-gradient(circle at 44% 16%, rgba(255, 255, 255, 0.8) 0 1.2px, transparent 1.4px),
      radial-gradient(circle at 60% 24%, rgba(255, 255, 255, 0.55) 0 1px, transparent 1.2px),
      radial-gradient(circle at 72% 78%, rgba(255, 255, 255, 0.72) 0 1.1px, transparent 1.3px),
      radial-gradient(circle at 84% 20%, rgba(255, 255, 255, 0.9) 0 1.3px, transparent 1.5px),
      radial-gradient(circle at 90% 50%, rgba(255, 255, 255, 0.56) 0 1px, transparent 1.2px);
    opacity: 0.75;
    pointer-events: none;
  }

  .linkstation-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(28px);
    pointer-events: none;
  }

  .linkstation-glow--left {
    left: 10%;
    bottom: 2%;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(70, 206, 116, 0.2), transparent 70%);
  }

  .linkstation-glow--right {
    right: 6%;
    top: 4%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(70, 206, 116, 0.32), transparent 72%);
  }

  .linkstation-shot {
    position: relative;
    z-index: 1;
    width: min(1380px, 100%);
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 26px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: var(--ls-shadow);
  }

  .linkstation-shot::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 180px;
    background: linear-gradient(180deg, rgba(245, 248, 247, 0), rgba(245, 248, 247, 0.98));
    pointer-events: none;
  }

  .linkstation-shot img {
    width: 100%;
    height: auto;
  }

  .linkstation-metrics {
    padding: 22px 0 88px;
  }

  .linkstation-metrics__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .linkstation-metric,
  .linkstation-feature {
    padding: 26px;
    border: 1px solid var(--ls-line);
    border-radius: 24px;
    background: var(--ls-surface);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
  }

  .linkstation-metric strong {
    display: block;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1;
  }

  .linkstation-metric span {
    display: block;
    margin-top: 10px;
    color: var(--ls-soft);
    line-height: 1.55;
  }

  .linkstation-overview {
    padding: 0 0 96px;
  }

  .linkstation-overview__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 28px;
    align-items: start;
  }

  .linkstation-sectionhead p {
    margin-left: 0;
  }

  .linkstation-featurelist {
    display: grid;
    gap: 18px;
  }

  .linkstation-feature {
    background: var(--ls-surface-strong);
  }

  .linkstation-feature h3 {
    margin: 0;
    font-size: 1.28rem;
  }

  .linkstation-feature p {
    margin: 10px 0 0;
    color: var(--ls-soft);
    line-height: 1.6;
  }

  .linkstation-cta {
    padding: 0 0 96px;
  }

  .linkstation-cta__panel {
    padding: 42px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 30px;
    background:
      radial-gradient(circle at top right, rgba(122, 255, 155, 0.22), transparent 34%),
      linear-gradient(135deg, rgba(7, 26, 39, 0.96), rgba(10, 42, 58, 0.96));
    text-align: center;
    box-shadow: var(--ls-shadow);
  }

  .linkstation-cta__panel h2 {
    max-width: 840px;
    margin-inline: auto;
    font-size: clamp(2rem, 4vw, 3.8rem);
  }

  .linkstation-cta__panel .linkstation-button {
    margin-top: 28px;
  }

  @media (max-width: 980px) {
    .linkstation-metrics__grid,
    .linkstation-overview__grid {
      grid-template-columns: 1fr;
    }

    .linkstation-stage {
      margin-top: 44px;
      padding-top: 20px;
    }
  }

  @media (max-width: 768px) {
    .linkstation-hero {
      padding: 52px 0 28px;
    }

    .linkstation-actions {
      flex-direction: column;
    }

    .linkstation-button {
      width: 100%;
    }

    .linkstation-stage {
      margin-top: 34px;
      padding-bottom: 0;
    }

    .linkstation-shot {
      border-radius: 20px;
    }

    .linkstation-shot::after {
      height: 90px;
    }

    .linkstation-metrics,
    .linkstation-overview,
    .linkstation-cta {
      padding-bottom: 64px;
    }

    .linkstation-metric,
    .linkstation-feature,
    .linkstation-cta__panel {
      padding: 20px;
      border-radius: 20px;
    }
  }
</style>
