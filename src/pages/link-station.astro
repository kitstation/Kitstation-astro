---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import HeroParticles from "../components/HeroParticles.astro";
import "../styles/global.css";

const metrics = [
  { value: "1 panel", label: "Todos tus canales en un solo lugar" },
  { value: "75%", label: "WhatsApp liderando las conversaciones" },
  { value: "25%", label: "Tasa de conversion visible para el equipo" }
];

const features = [
  {
    title: "Bandeja unificada",
    text: "Centraliza WhatsApp, Instagram y otros puntos de contacto sin perder contexto."
  },
  {
    title: "Visibilidad del equipo",
    text: "Supervisa agentes, conversaciones activas y ventas cerradas desde el tablero."
  },
  {
    title: "Analitica clara",
    text: "Mide conversion, volumen por canal e insights del periodo en segundos."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "LinkStation",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  description:
    "LinkStation centraliza conversaciones, agentes y ventas en un CRM visual para equipos comerciales."
};
---

<BaseLayout
  title="LinkStation | CRM para centralizar conversaciones y ventas"
  description="LinkStation es una landing para presentar un CRM visual que organiza conversaciones, equipo y conversiones desde un solo tablero."
  image="/images/linkstation-crm.png"
  imageAlt="Vista del dashboard de LinkStation CRM"
  structuredData={structuredData}
>
  <Header />

  <main class="linkstation-page">
    <section class="hero linkstation-hero">
      <HeroParticles />
      <div class="container linkstation-hero__inner">
        <div class="linkstation-copy reveal reveal-up" data-reveal="up">
          <h1>
            <span>Gestiona todos tus chats de clientes</span>
            <span>y vendedores desde un solo lugar.</span>
          </h1>
          <p>
            Responde más rápido, mide el rendimiento de tus agentes y mantén el
            control de cada conversación desde Linkstation
          </p>

          <div class="linkstation-actions">
            <a class="linkstation-button linkstation-button--primary" href="/contactanos/">
              Solicitar demo
            </a>
            <a class="linkstation-button linkstation-button--ghost" href="#overview">
              Ver tablero
            </a>
          </div>
        </div>

        <div class="linkstation-stage reveal reveal-up" data-reveal="up" id="overview">
          <figure class="linkstation-shot">
            <img
              src="/images/linkstation-crm.png"
              alt="Dashboard principal de LinkStation CRM"
              width="1912"
              height="913"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="linkstation-metrics">
      <div class="container linkstation-metrics__grid">
        {metrics.map((item) => (
          <article class="linkstation-metric reveal reveal-up" data-reveal="up">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="linkstation-overview">
      <div class="container linkstation-overview__grid">
        <div class="linkstation-sectionhead reveal reveal-left" data-reveal="left">
          <span>VISION GENERAL</span>
          <h2>Una interfaz limpia para entender el estado comercial sin esfuerzo.</h2>
          <p>
            LinkStation ordena el trabajo diario con tarjetas de rendimiento,
            lectura por canal e insights accionables para tomar decisiones mas
            rapidas.
          </p>
        </div>

        <div class="linkstation-featurelist">
          {features.map((item) => (
            <article class="linkstation-feature reveal reveal-right" data-reveal="right">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="linkstation-cta">
      <div class="container">
        <div class="linkstation-cta__panel reveal reveal-up" data-reveal="up">
          <span>LINKSTATION</span>
          <h2>Convierte conversaciones en seguimiento, equipo y ventas visibles.</h2>
          <a class="linkstation-button linkstation-button--light" href="/contactanos/">
            Quiero una demo
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</BaseLayout>

<style>
  :root {
    --ls-surface: rgba(255, 255, 255, 0.88);
    --ls-surface-strong: rgba(255, 255, 255, 0.96);
    --ls-line: rgba(19, 19, 19, 0.08);
    --ls-text: #202125;
    --ls-soft: #5f6674;
    --ls-accent: #4fd46f;
    --ls-accent-dark: #2b3cff;
    --ls-shadow: 0 24px 70px rgba(5, 14, 35, 0.12);
  }

  .linkstation-page {
    background: linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
    color: var(--ls-text);
  }

  .linkstation-hero {
    position: relative;
    overflow: hidden;
    min-height: auto;
    padding: 78px 0 40px;
    background: transparent;
  }

  .linkstation-hero::after {
    display: none;
  }

  .linkstation-hero__inner {
    position: relative;
    z-index: 2;
  }

  .linkstation-copy {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .linkstation-badge,
  .linkstation-sectionhead span,
  .linkstation-cta__panel span {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 16px;
    border: 1px solid rgba(19, 19, 19, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: #3d4655;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .linkstation-copy h1,
  .linkstation-sectionhead h2,
  .linkstation-cta__panel h2 {
    margin: 20px 0 0;
    font-size: clamp(2.5rem, 4.8vw, 4.2rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  .linkstation-copy h1 {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: fit-content;
    margin-inline: auto;
  }

  .linkstation-copy h1 span {
    display: block;
    white-space: nowrap;
  }

  .linkstation-copy h1 span + span {
    margin-top: 0.14em;
  }

  .linkstation-copy p,
  .linkstation-sectionhead p {
    max-width: 760px;
    margin: 22px auto 0;
    color: #4f5665;
    font-size: clamp(0.92rem, 1.35vw, 1.08rem);
    line-height: 1.55;
  }

  .linkstation-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .linkstation-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 0 26px;
    border: 1px solid transparent;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 600;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .linkstation-button:hover {
    transform: translateY(-2px);
  }

  .linkstation-button--primary {
    background: linear-gradient(135deg, #2c42ff 0%, #4a36f5 100%);
    color: #fff;
    box-shadow: 0 18px 42px rgba(44, 66, 255, 0.24);
  }

  .linkstation-button--ghost {
    border-color: rgba(19, 19, 19, 0.12);
    background: rgba(255, 255, 255, 0.76);
    color: #202125;
  }

  .linkstation-button--ghost:hover {
    border-color: rgba(44, 66, 255, 0.24);
    background: rgba(255, 255, 255, 0.94);
    color: #202125;
  }

  .linkstation-button--light {
    background: #fff;
    color: #2432d8;
  }

  .linkstation-stage {
    position: relative;
    margin-top: 56px;
    padding: 34px 0 24px;
  }

  .linkstation-shot {
    position: relative;
    z-index: 1;
    width: min(1380px, 100%);
    margin: 0 auto;
    border: 1px solid rgba(19, 19, 19, 0.08);
    border-radius: 26px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--ls-shadow);
  }

  .linkstation-shot::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 180px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96));
    pointer-events: none;
  }

  .linkstation-shot img {
    width: 100%;
    height: auto;
  }

  .linkstation-metrics {
    padding: 22px 0 88px;
  }

  .linkstation-metrics__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .linkstation-metric,
  .linkstation-feature {
    padding: 26px;
    border: 1px solid var(--ls-line);
    border-radius: 24px;
    background: var(--ls-surface);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 40px rgba(5, 14, 35, 0.06);
  }

  .linkstation-metric strong {
    display: block;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1;
  }

  .linkstation-metric span {
    display: block;
    margin-top: 10px;
    color: var(--ls-soft);
    line-height: 1.55;
  }

  .linkstation-overview {
    padding: 0 0 96px;
  }

  .linkstation-overview__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 28px;
    align-items: start;
  }

  .linkstation-sectionhead p {
    margin-left: 0;
  }

  .linkstation-featurelist {
    display: grid;
    gap: 18px;
  }

  .linkstation-feature {
    background: var(--ls-surface-strong);
  }

  .linkstation-feature h3 {
    margin: 0;
    font-size: 1.28rem;
  }

  .linkstation-feature p {
    margin: 10px 0 0;
    color: var(--ls-soft);
    line-height: 1.6;
  }

  .linkstation-cta {
    padding: 0 0 96px;
  }

  .linkstation-cta__panel {
    padding: 42px;
    border: 1px solid rgba(19, 19, 19, 0.08);
    border-radius: 30px;
    background:
      radial-gradient(circle at top right, rgba(122, 146, 255, 0.18), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(245, 248, 255, 0.98));
    text-align: center;
    box-shadow: var(--ls-shadow);
  }

  .linkstation-cta__panel span {
    border-color: rgba(19, 19, 19, 0.08);
    background: rgba(255, 255, 255, 0.82);
    color: #3d4655;
  }

  .linkstation-cta__panel h2 {
    max-width: 840px;
    margin-inline: auto;
    font-size: clamp(2rem, 4vw, 3.8rem);
  }

  .linkstation-cta__panel .linkstation-button {
    margin-top: 28px;
  }

  @media (max-width: 980px) {
    .linkstation-metrics__grid,
    .linkstation-overview__grid {
      grid-template-columns: 1fr;
    }

    .linkstation-stage {
      margin-top: 44px;
      padding-top: 20px;
    }
  }

  @media (max-width: 768px) {
    .linkstation-hero {
      padding: 52px 0 28px;
    }

    .linkstation-actions {
      flex-direction: column;
    }

    .linkstation-button {
      width: 100%;
    }

    .linkstation-stage {
      margin-top: 34px;
      padding-bottom: 0;
    }

    .linkstation-shot {
      border-radius: 20px;
    }

    .linkstation-shot::after {
      height: 90px;
    }

    .linkstation-metrics,
    .linkstation-overview,
    .linkstation-cta {
      padding-bottom: 64px;
    }

    .linkstation-metric,
    .linkstation-feature,
    .linkstation-cta__panel {
      padding: 20px;
      border-radius: 20px;
    }
  }
</style>
