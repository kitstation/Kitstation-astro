{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/animacion-digital/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/enviar-formulario/?$",
			"dest": "_render"
		},
		{
			"src": "^/automatizacion-con-ia/?$",
			"dest": "_render"
		},
		{
			"src": "^/campanas-digitales/?$",
			"dest": "_render"
		},
		{
			"src": "^/consultoria-y-soporte/?$",
			"dest": "_render"
		},
		{
			"src": "^/contactanos/?$",
			"dest": "_render"
		},
		{
			"src": "^/creacion-de-contenido/?$",
			"dest": "_render"
		},
		{
			"src": "^/diseno-de-pagina-web/?$",
			"dest": "_render"
		},
		{
			"src": "^/landing-paginas-webs/?$",
			"dest": "_render"
		},
		{
			"src": "^/libro-de-reclamaciones/?$",
			"dest": "_render"
		},
		{
			"src": "^/nosotros/?$",
			"dest": "_render"
		},
		{
			"src": "^/politicas-y-privacidad/?$",
			"dest": "_render"
		},
		{
			"src": "^/posicionamiento-seo/?$",
			"dest": "_render"
		},
		{
			"src": "^/preguntas-frecuentes/?$",
			"dest": "_render"
		},
		{
			"src": "^/terminos-y-condiciones/?$",
			"dest": "_render"
		},
		{
			"src": "^/websites/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}